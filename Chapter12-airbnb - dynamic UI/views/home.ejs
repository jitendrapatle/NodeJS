<!DOCTYPE html>
<html lang="en">

<%- include('partials/head') %>

<body class="bg-gradient-to-br from-gray-100 via-white to-pink-50 min-h-screen">

<%- include('partials/header') %>

    <!-- Hero Section -->
    <section class="text-center py-14 px-6">
        <h1 class="text-5xl md:text-6xl font-extrabold text-gray-800">
            Find Your
            <span class="text-rose-500">Perfect Stay</span>
        </h1>

        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
            Explore unique homes, cozy apartments, and luxurious villas from
            hosts around the world.
        </p>
    </section>

    <!-- Homes -->
    <main class="max-w-7xl mx-auto px-6 pb-12">

        <h2 class="text-3xl font-bold text-gray-800 mb-8">
            Registered Homes
        </h2>

        <% if(registredHomes.length===0){ %>

            <div class="bg-white rounded-xl shadow-md p-10 text-center">
                <h3 class="text-2xl font-semibold text-gray-600">
                    No homes available yet.
                </h3>

                <p class="text-gray-500 mt-2">
                    Be the first one to list your home.
                </p>
            </div>

        <% } else { %>

            <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">

                <% registredHomes.forEach(home=>{ %>

                    <div
                        class="bg-white rounded-2xl shadow-lg hover:shadow-2xl hover:-translate-y-2 transition duration-300 overflow-hidden">

                        <!-- Image Placeholder -->
                        <div
                            class="h-56 bg-gradient-to-r from-rose-400 via-pink-400 to-orange-300 flex items-center justify-center">

                            <span class="text-7xl">🏡</span>

                        </div>

                        <!-- Card Content -->
                        <div class="p-6">

                            <h3 class="text-2xl font-bold text-gray-800">
                                <%= home.houseName %>
                            </h3>

                            <p class="text-gray-500 mt-2">
                                Comfortable stay with modern amenities and a
                                welcoming atmosphere.
                            </p>

                            <button
                                class="mt-6 w-full bg-rose-500 hover:bg-rose-600 text-white py-3 rounded-xl font-semibold transition duration-300">
                                View Details
                            </button>

                        </div>

                    </div>

                <% }) %>

            </div>

        <% } %>

    </main>

</body>
</html>