<!DOCTYPE html>
<html lang="en">

<%- include('partials/head') %>

<body class="bg-gradient-to-br from-gray-100 via-white to-pink-50 min-h-screen">

    <!-- Navbar -->
    <%- include('partials/header') %>

    <!-- Success Section -->
    <main class="flex items-center justify-center px-4 py-20">

        <div class="max-w-md w-full bg-white rounded-3xl shadow-2xl p-10 text-center">

            <!-- Success Icon -->
            <div
                class="w-24 h-24 mx-auto rounded-full bg-green-100 flex items-center justify-center mb-6">
                <span class="text-5xl">✅</span>
            </div>

            <!-- Heading -->
            <h1 class="text-4xl font-extrabold text-gray-800">
                Home Registered!
            </h1>

            <!-- Message -->
            <p class="mt-4 text-gray-600 leading-relaxed">
                Your home has been registered successfully and is now available
                in the listings.
            </p>

            <!-- Buttons -->
            <div class="mt-8 flex flex-col sm:flex-row gap-4">

                <a href="/"
                    class="flex-1 bg-gradient-to-r from-rose-500 to-pink-500 text-white py-3 rounded-xl font-semibold hover:shadow-lg hover:scale-105 transition duration-300">
                    🏠 Go Home
                </a>

                <a href="/host/add-home"
                    class="flex-1 border-2 border-rose-500 text-rose-500 py-3 rounded-xl font-semibold hover:bg-rose-500 hover:text-white transition duration-300">
                    + Add Another
                </a>

            </div>

        </div>

    </main>

</body>

</html>