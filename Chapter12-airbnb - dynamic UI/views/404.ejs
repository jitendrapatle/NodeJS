<!DOCTYPE html>
<html lang="en">

<%- include('partials/head') %>

<body class="bg-gradient-to-br from-gray-100 via-white to-pink-50 min-h-screen">

    <!-- Navbar -->
    <%- include('partials/header') %>

    <!-- 404 Section -->
    <main class="flex items-center justify-center px-4 py-20">

        <div class="max-w-lg w-full bg-white rounded-3xl shadow-2xl p-10 text-center">

            <!-- Illustration -->
            <div
                class="w-28 h-28 mx-auto rounded-full bg-red-100 flex items-center justify-center mb-6">
                <span class="text-6xl">🔍</span>
            </div>

            <!-- Error Code -->
            <h1 class="text-7xl font-extrabold text-rose-500">
                404
            </h1>

            <!-- Heading -->
            <h2 class="mt-4 text-3xl font-bold text-gray-800">
                Oops! Page Not Found
            </h2>

            <!-- Description -->
            <p class="mt-4 text-gray-600 leading-relaxed">
                Sorry, the page you're looking for doesn't exist or may have
                been moved. Let's get you back to exploring amazing homes.
            </p>

            <!-- Buttons -->
            <div class="mt-8 flex flex-col sm:flex-row gap-4">

                <a href="/"
                    class="flex-1 bg-gradient-to-r from-rose-500 to-pink-500 text-white py-3 rounded-xl font-semibold hover:shadow-lg hover:scale-105 transition duration-300">
                    🏠 Go Home
                </a>

                <a href="/host/add-home"
                    class="flex-1 border-2 border-rose-500 text-rose-500 py-3 rounded-xl font-semibold hover:bg-rose-500 hover:text-white transition duration-300">
                    + Add Home
                </a>

            </div>

        </div>

    </main>

</body>

</html>